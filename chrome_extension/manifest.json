{
    "manifest_version": 3,
    "name": "PW2D Product Scraper",
    "version": "1.0",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "alarms"
    ],
    "host_permissions": [
        "https://www.amazon.com/*",
        "https://www.amazon.co.uk/*",
        "http://127.0.0.1:8003/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "images/icon16.png",
            "48": "images/icon48.png",
            "128": "images/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.amazon.com/*",
                "*://*.amazon.co.uk/*",
                "*://*.amazon.de/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}